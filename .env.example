# =========================================================
# Alea Webapp — Environment Variables
# =========================================================
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.

# ----------------------------------------------------------
# Supabase — Client (public, safe to expose in browser)
# Get from: Supabase Dashboard > Project Settings > API
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ----------------------------------------------------------
# Supabase — Server only (NEVER expose to browser)
# Get from: Supabase Dashboard > Project Settings > API > service_role key
# ----------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------------------
# Auth session (legacy — NOT used by the current runtime)
# This variable was used by the pre-Supabase HMAC session implementation
# (removed in M3). It is not referenced anywhere in app/, lib/, or middleware.ts.
# Keep only if you need to roll back past M3.
# ----------------------------------------------------------
AUTH_SESSION_SECRET=change-me-in-production-min-32-chars

# ----------------------------------------------------------
# App
# ----------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public application URL — reserved for future OAuth/redirect configuration.
# NOT currently consumed by any runtime code (app/, lib/, middleware.ts).
# Set this when wiring OAuth provider redirects or absolute URL generation.

# Base URL for API calls — defaults to /api (relative). Override for CDN/proxy deployments.
NEXT_PUBLIC_API_URL=/api
