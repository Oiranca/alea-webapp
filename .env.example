# ============================================================
# SUPABASE
# Dashboard: supabase.com → your project → Project Settings → API
# ============================================================

# Project URL
# Location: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key — safe to expose in the browser
# Format: sb_publishable_xxxxxxxx
# Location: Project Settings → API → Publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Secret key — SERVER ONLY, never expose to the browser
# Format: sb_secret_xxxxxxxx
# Location: Project Settings → API Keys → Secret keys → default
SUPABASE_SECRET_DEFAULT_KEY=sb_secret_xxxxxxxxxxxxxxxx

# ============================================================
# APPLICATION
# ============================================================

# Base URL of the app (used for auth callbacks, redirects, and server-side cookie security decisions)
# IMPORTANT: Supabase and CSRF cookies are only marked `Secure` when this is set to an `https://` URL.
# Use `http://localhost:3000` for local development, but set this to your real `https://` app URL in deployed environments.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable this only when the deployment ingress strips and rewrites both `x-real-ip`
# and `x-forwarded-for` before requests reach the app runtime.
TRUST_PROXY_HEADERS=false

# Comma-separated CIDR allowlist for reverse proxies that are permitted to supply `x-forwarded-for`.
# Only requests arriving from one of these source IP ranges will trust the first forwarded address for rate limiting,
# and only when TRUST_PROXY_HEADERS=true. Everything else falls back to `x-real-ip` (or `local` if unavailable).
# Set this explicitly in deployed environments, and ensure your ingress strips and overwrites inbound `x-real-ip`
# and `x-forwarded-for`.
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Optional API base URL override for the frontend.
# If unset, the runtime defaults to `/api`.
# Only set this when the browser should call a different API base URL.
NEXT_PUBLIC_API_URL=/api

# External URL for the association link in the footer
NEXT_PUBLIC_ASSOCIATION_URL=

# Legacy — not used by the current runtime (no process.env.AUTH_SESSION_SECRET in app/, lib/, or middleware.ts).
# Keep only if you need to roll back past milestone M3 (pre-Supabase auth).
AUTH_SESSION_SECRET=legacy-unused-by-current-runtime

# Secret used to authenticate cron job requests (set this to a random string in production)
# Vercel injects this automatically for Vercel Cron — set it manually for self-hosted deployments
CRON_SECRET=your-random-cron-secret
