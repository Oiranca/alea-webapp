# ============================================================
# SUPABASE — Project API keys
# Dashboard: supabase.com → your project → Project Settings → API
#
# Key migration note (2025):
#   Supabase is transitioning from long-lived JWT keys to
#   short-lived rotatable keys (sb_publishable_* / sb_secret_*).
#   The old anon/service_role JWTs are marked "Legacy" in the
#   dashboard but remain valid during the transition period.
# ============================================================

# Your project URL
# Location: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key — safe to expose in the browser
# Format: sb_publishable_xxxxxxxx (new) or a JWT string (legacy anon key)
# Location: Project Settings → API → Publishable key  (or "Legacy anon key")
# Previously named: NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# Service role secret — SERVER ONLY, never expose to the browser
# Format: sb_secret_xxxxxxxx (new) or a JWT string (legacy service_role key)
# Location: Project Settings → API → Secret key  (or "Legacy service_role key")
# Bypasses Row Level Security — treat like a root password
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# APPLICATION
# ============================================================

# Base URL of the app (used for auth callbacks and redirects)
# Local: http://localhost:3000  |  Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret used to sign/encrypt auth sessions (min 32 chars, generate with: openssl rand -base64 32)
AUTH_SESSION_SECRET=your-auth-session-secret-min-32-chars
